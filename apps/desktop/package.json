{
  "name": "sni-hunter-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Dark-mode desktop GUI wrapping tools/sni-hunter.sh, packaged as AppImage and .deb",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare-sidecar": "bash scripts/prepare-sidecar.sh",
    "tauri": "tauri",
    "tauri:dev": "pnpm prepare-sidecar && tauri dev",
    "tauri:build": "pnpm prepare-sidecar && tauri build --bundles deb,appimage",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "@tauri-apps/plugin-fs": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-shell": "^2.3.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2",
    "vite": "^6.3.5"
  }
}
